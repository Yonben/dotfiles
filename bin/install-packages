#!/usr/bin/env sh
set -eu

log_info() { printf '%s\n' "[info] $*"; }
log_done() { printf '%s\n' "[done] $*"; }
log_warn() { printf '%s\n' "[warn] $*"; }
log_fail() { printf '%s\n' "[fail] $*"; }
is_macos() { [ "$(uname -s)" = "Darwin" ]; }
is_linux() { [ "$(uname -s)" = "Linux" ]; }
has_command() { command -v "$1" >/dev/null 2>&1; }
is_root() { [ "$(id -u)" -eq 0 ]; }

assert_contains() {
  haystack="$1"
  needle="$2"
  if printf '%s' "$haystack" | grep -F -- "$needle" >/dev/null 2>&1; then
    return 0
  fi

  printf '%s\n' "missing expected output: $needle" >&2
  return 1
}

assert_not_contains() {
  haystack="$1"
  needle="$2"
  if printf '%s' "$haystack" | grep -F -- "$needle" >/dev/null 2>&1; then
    printf '%s\n' "unexpected output present: $needle" >&2
    return 1
  fi

  return 0
}

assert_occurrences() {
  haystack="$1"
  needle="$2"
  expected_count="$3"
  actual_count="$(printf '%s' "$haystack" | grep -F -c -- "$needle" || true)"

  if [ "$actual_count" -eq "$expected_count" ]; then
    return 0
  fi

  printf '%s\n' "expected $expected_count occurrences of: $needle (found $actual_count)" >&2
  return 1
}

emit_follow_up_checklist_self_test_output() {
  FOLLOW_UPS_FILE="$(mktemp "${TMPDIR:-/tmp}/install-packages-follow-ups.XXXXXX")"
  trap 'rm -f "$FOLLOW_UPS_FILE"' EXIT HUP INT TERM
  add_shell_follow_up
  add_universe_follow_up
  add_starship_follow_up
  add_root_rerun_follow_up
  print_follow_ups
}

run_self_test() {
  case "${2:-}" in
    follow-up-checklist)
      output="$(emit_follow_up_checklist_self_test_output 2>&1 || true)"
      assert_contains "$output" "Before you finish setup, review these follow-up steps:"
      assert_occurrences "$output" "Before you finish setup, review these follow-up steps:" 1
      assert_contains "$output" "- If you want your user shell to default to zsh, run: chsh -s \"\$(command -v zsh)\""
      assert_contains "$output" "- If apt still cannot find required packages, enable the Ubuntu universe repository, refresh apt metadata, and rerun the installer: sudo add-apt-repository -y universe && sudo apt update"
      assert_contains "$output" "- If you want the prompt theme now, install starship manually: curl -sS https://starship.rs/install.sh | sh"
      assert_contains "$output" "- If package installation needed elevated privileges, rerun the installer as root: sudo ./bin/install-packages"
      assert_not_contains "$output" "Follow-up:"
      return 0
      ;;
    env-leak-ignored)
      output="$(
        INSTALL_PACKAGES_SELF_TEST_SCENARIO="follow-up-checklist" \
          PATH="/usr/bin:/bin" \
          sh "$0" 2>&1 || true
      )"
      assert_contains "$output" "[fail] Automatic package installation is unavailable: Homebrew was not found on macOS"
      assert_contains "$output" "- Install Homebrew from https://brew.sh, then rerun ./bin/install-packages to install the required packages automatically"
      assert_not_contains "$output" "- If apt still cannot find required packages, enable the Ubuntu universe repository, refresh apt metadata, and rerun the installer: sudo add-apt-repository -y universe && sudo apt update"
      assert_not_contains "$output" "- If package installation needed elevated privileges, rerun the installer as root: sudo ./bin/install-packages"
      assert_not_contains "$output" "- If you want the prompt theme now, install starship manually: curl -sS https://starship.rs/install.sh | sh"
      return 0
      ;;
  esac

  printf '%s\n' "unknown self-test: ${2:-}" >&2
  return 1
}

select_package_manager() {
  if is_macos && has_command brew; then
    printf '%s\n' brew
    return 0
  fi

  if is_linux; then
    if has_command apt-get; then
      printf '%s\n' apt-get
      return 0
    fi

    if has_command brew; then
      printf '%s\n' brew
      return 0
    fi
  fi

  return 1
}

log_info "Starting package installation"

PACKAGE_MANAGER="$(select_package_manager || true)"
APT_REQUIRED_PACKAGES="zsh git fzf zoxide bat eza"
APT_BEST_EFFORT_PACKAGES="starship"
BREW_REQUIRED_PACKAGES="zsh git fzf zoxide bat eza starship"
FOLLOW_UPS_FILE="$(mktemp "${TMPDIR:-/tmp}/install-packages-follow-ups.XXXXXX")"

cleanup() {
  rm -f "$FOLLOW_UPS_FILE"
}

trap cleanup EXIT HUP INT TERM

add_follow_up() {
  printf '%s\n' "$1" >> "$FOLLOW_UPS_FILE"
}

add_shell_follow_up() {
  add_follow_up 'If you want your user shell to default to zsh, run: chsh -s "$(command -v zsh)"'
}

add_root_rerun_follow_up() {
  add_follow_up "If package installation needed elevated privileges, rerun the installer as root: sudo ./bin/install-packages"
}

add_universe_follow_up() {
  add_follow_up "If apt still cannot find required packages, enable the Ubuntu universe repository, refresh apt metadata, and rerun the installer: sudo add-apt-repository -y universe && sudo apt update"
}

add_starship_follow_up() {
  add_follow_up "If you want the prompt theme now, install starship manually: curl -sS https://starship.rs/install.sh | sh"
}

print_follow_ups() {
  [ -s "$FOLLOW_UPS_FILE" ] || return 0

  printf '%s\n' "Before you finish setup, review these follow-up steps:"
  sort -u "$FOLLOW_UPS_FILE" | while IFS= read -r follow_up || [ -n "$follow_up" ]; do
    [ -n "$follow_up" ] || continue
    printf '%s\n' "- $follow_up"
  done
}

finish() {
  status="$1"
  print_follow_ups
  exit "$status"
}

if [ "${1:-}" = "--self-test" ]; then
  run_self_test "$@"
  exit $?
fi

add_shell_follow_up

install_brew_package() {
  package="$1"

  log_info "Attempting Homebrew package install: $package"
  set +e
  output="$(brew install "$package" 2>&1)"
  status=$?
  set -e

  if [ -n "$output" ]; then
    printf '%s\n' "$output"
  fi

  if [ "$status" -eq 0 ]; then
    log_done "Installed Homebrew package: $package"
    return 0
  fi

  log_warn "Homebrew install failed for package: $package"
  if [ "$package" = "starship" ]; then
    add_starship_follow_up
  fi
  return 1
}

apt_permission_denied() {
  output="$1"
  case "$output" in
    *"Permission denied"*|*"are you root"*|*"Could not open lock file"*|*"Unable to acquire the dpkg frontend lock"*)
      return 0
      ;;
  esac

  return 1
}

apt_missing_package() {
  output="$1"
  case "$output" in
    *"Unable to locate package"*|*"has no installation candidate"*|*"No package matching"*)
      return 0
      ;;
  esac

  return 1
}

apt_refresh_metadata_if_needed() {
  if ! is_root; then
    log_info "Skipping apt metadata refresh until privileges are available"
    return 0
  fi

  log_info "Refreshing apt package metadata"
  set +e
  output="$(apt-get update 2>&1)"
  status=$?
  set -e

  if [ "$status" -eq 0 ]; then
    return 0
  fi

  printf '%s\n' "$output" >&2
  log_warn "Apt metadata refresh failed"
  return 1
}

install_apt_package() {
  package="$1"
  required="$2"
  set +e
  output="$(apt-get install -y "$package" 2>&1)"
  status=$?
  set -e

  if [ "$status" -eq 0 ]; then
    log_done "Installed apt package: $package"
    return 0
  fi

  printf '%s\n' "$output" >&2

  if apt_permission_denied "$output"; then
    log_warn "Insufficient privileges to install apt package: $package"
    add_root_rerun_follow_up
    return 1
  fi

  if apt_missing_package "$output"; then
    log_warn "Apt package is unavailable: $package"
    if [ "$package" = "starship" ]; then
      add_starship_follow_up
    else
      add_universe_follow_up
    fi
    return 1
  fi

  log_warn "Apt install failed for $package"
  if [ "$required" = "required" ]; then
    add_root_rerun_follow_up
  fi
  return 1
}

if [ "$PACKAGE_MANAGER" = "brew" ]; then
  if is_macos; then
    log_info "Selected package manager: Homebrew on macOS"
  else
    log_info "Selected package manager: Homebrew"
  fi

  missing_brew_packages=""
  for package in $BREW_REQUIRED_PACKAGES; do
    if ! install_brew_package "$package"; then
      missing_brew_packages="${missing_brew_packages}${missing_brew_packages:+ }$package"
    fi
  done

  if [ -n "$missing_brew_packages" ]; then
    log_fail "Required Homebrew packages remain unavailable: $missing_brew_packages"
    finish 1
  fi

  finish 0
fi

if [ "$PACKAGE_MANAGER" = "apt-get" ]; then
  missing_required_packages=""

  if ! apt_refresh_metadata_if_needed; then
    log_warn "Continuing with apt package installation despite metadata refresh failure"
  fi

  for package in $APT_REQUIRED_PACKAGES; do
    if ! install_apt_package "$package" required; then
      missing_required_packages="${missing_required_packages}${missing_required_packages:+ }$package"
    fi
  done

  for package in $APT_BEST_EFFORT_PACKAGES; do
    if ! install_apt_package "$package" best-effort; then
      log_warn "Continuing without optional apt package: $package"
    fi
  done

  if [ -n "$missing_required_packages" ]; then
    log_fail "Required apt packages remain unavailable: $missing_required_packages"
    finish 1
  fi

  finish 0
fi

if is_macos; then
  log_fail "Automatic package installation is unavailable: Homebrew was not found on macOS"
  add_follow_up "Install Homebrew from https://brew.sh, then rerun ./bin/install-packages to install the required packages automatically"
else
  log_fail "Automatic package installation is unavailable: no supported package manager was found"
  add_follow_up "Install the required packages manually: zsh git fzf zoxide bat eza starship"
fi

log_warn "Cannot continue with automatic package installation on this platform"
finish 1
