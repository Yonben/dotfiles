#!/usr/bin/env sh
set -eu

DOTFILES_DIR_DEFAULT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
DOTFILES_DIR="${DOTFILES_DIR_OVERRIDE:-$DOTFILES_DIR_DEFAULT}"

log_info() { printf '%s\n' "[info] $*"; }
log_done() { printf '%s\n' "[done] $*"; }
log_warn() { printf '%s\n' "[warn] $*"; }
log_fail() { printf '%s\n' "[fail] $*"; }
is_root() { [ "$(id -u)" -eq 0 ]; }

assert_contains() {
  haystack="$1"
  needle="$2"
  if printf '%s' "$haystack" | grep -F -- "$needle" >/dev/null 2>&1; then
    return 0
  fi

  printf '%s\n' "missing expected output: $needle" >&2
  return 1
}

assert_occurrences() {
  haystack="$1"
  needle="$2"
  expected_count="$3"
  actual_count="$(printf '%s' "$haystack" | grep -F -c -- "$needle" || true)"

  if [ "$actual_count" -eq "$expected_count" ]; then
    return 0
  fi

  printf '%s\n' "expected $expected_count occurrences of: $needle (found $actual_count)" >&2
  return 1
}

cleanup_dir() {
  rm -rf "$1"
}

create_self_test_fixture() {
  fixture_root="$1"

  mkdir -p \
    "$fixture_root/bin" \
    "$fixture_root/git" \
    "$fixture_root/local" \
    "$fixture_root/starship" \
    "$fixture_root/zsh/plugins"

  cp "$0" "$fixture_root/bin/bootstrap"
  cat > "$fixture_root/bin/install-packages" <<'EOF'
#!/usr/bin/env sh
printf '%s\n' "Before you finish setup, review these follow-up steps:"
printf '%s\n' '- If you want your user shell to default to zsh, run: chsh -s "$(command -v zsh)"'
printf '%s\n' "- If package installation needed elevated privileges, rerun the installer as root: sudo ./bin/install-packages"
exit 1
EOF
  cat > "$fixture_root/bin/install-zsh-plugins" <<'EOF'
#!/usr/bin/env sh
printf '%s\n' "[done] Installed zsh plugin: zsh-autosuggestions"
printf '%s\n' "[done] Installed zsh plugin: fast-syntax-highlighting"
EOF
  cat > "$fixture_root/bin/fzf" <<'EOF'
#!/usr/bin/env sh
if [ "${1:-}" = "--zsh" ]; then
  printf '%s\n' 'bindkey "^R" redo'
  exit 0
fi
exit 1
EOF
  cat > "$fixture_root/local/zsh.local.example" <<'EOF'
# local zsh overrides
EOF
  cat > "$fixture_root/local/gitconfig.local.example" <<'EOF'
[user]
	# local git identity
EOF
  cp "$DOTFILES_DIR/zsh/.zshrc" "$fixture_root/zsh/.zshrc"
  if [ -f "$DOTFILES_DIR/zsh/aliases.zsh" ]; then
    cp "$DOTFILES_DIR/zsh/aliases.zsh" "$fixture_root/zsh/aliases.zsh"
  fi
  if [ -f "$DOTFILES_DIR/zsh/git-functions.zsh" ]; then
    cp "$DOTFILES_DIR/zsh/git-functions.zsh" "$fixture_root/zsh/git-functions.zsh"
  fi
  cat > "$fixture_root/git/.gitconfig" <<'EOF'
[include]
	path = ~/dotfiles/local/gitconfig.local
EOF
  cat > "$fixture_root/starship/starship.toml" <<'EOF'
add_newline = false
EOF

  touch "$fixture_root/zsh/plugins/.gitkeep"

  chmod +x \
    "$fixture_root/bin/bootstrap" \
    "$fixture_root/bin/install-packages" \
    "$fixture_root/bin/install-zsh-plugins" \
    "$fixture_root/bin/fzf"
}

print_shell_follow_up() {
  printf '%s\n' "Before you finish setup, review this follow-up step:"
  printf '%s\n' '- If you want your user shell to default to zsh, run: chsh -s "$(command -v zsh)"'
}

backup_target() {
  target="$1"
  if [ -e "$target" ] || [ -L "$target" ]; then
    backup_path="$target.backup.$(date +%Y%m%d%H%M%S)"
    mv "$target" "$backup_path"
    log_warn "Created backup: $target -> $backup_path"
  fi
}

link_file() {
  source_path="$1"
  target_path="$2"

  mkdir -p "$(dirname "$target_path")"

  if [ -L "$target_path" ] && [ "$(readlink "$target_path")" = "$source_path" ]; then
    log_info "Skipping existing link: $target_path"
    return 0
  fi

  if [ -e "$target_path" ] || [ -L "$target_path" ]; then
    backup_target "$target_path"
  fi

  ln -s "$source_path" "$target_path"
  log_done "Linked $target_path -> $source_path"
}

seed_local_file() {
  example_path="$1"
  local_path="$2"

  if [ ! -e "$local_path" ]; then
    cp "$example_path" "$local_path"
    log_done "Seeded local file: $local_path"
  fi
}

run_progress_output_self_test() {
  tmp_fixture="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-fixture.XXXXXX")"
  tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-progress.XXXXXX")"
  create_self_test_fixture "$tmp_fixture"

  output="$(
    HOME="$tmp_home" \
      DOTFILES_DIR_OVERRIDE="$tmp_fixture" \
      "$tmp_fixture/bin/bootstrap" 2>&1
  )"

  assert_contains "$output" "[info] Starting bootstrap"
  assert_contains "$output" "[done] Seeded local file: $tmp_fixture/local/zsh.local"
  assert_contains "$output" "[done] Seeded local file: $tmp_fixture/local/gitconfig.local"
  assert_contains "$output" "[done] Linked $tmp_home/.zshrc -> $tmp_fixture/zsh/.zshrc"
  assert_contains "$output" "[done] Linked $tmp_home/.gitconfig -> $tmp_fixture/git/.gitconfig"
  assert_contains "$output" "[done] Linked $tmp_home/.config/starship.toml -> $tmp_fixture/starship/starship.toml"
  assert_contains "$output" "[done] Installed zsh plugin: zsh-autosuggestions"
  assert_contains "$output" "[done] Installed zsh plugin: fast-syntax-highlighting"
  assert_contains "$output" 'Before you finish setup, review this follow-up step:'
  assert_contains "$output" '- If you want your user shell to default to zsh, run: chsh -s "$(command -v zsh)"'

  cleanup_dir "$tmp_fixture"
  cleanup_dir "$tmp_home"
}

run_install_delegation_self_test() {
  tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-install.XXXXXX")"
  tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-home.XXXXXX")"
  tmp_fixture="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-fixture.XXXXXX")"
  create_self_test_fixture "$tmp_fixture"

  mkdir -p "$tmp_root/bin"
  cat > "$tmp_root/bin/uname" <<'EOF'
#!/usr/bin/env sh
echo Linux
EOF
  cat > "$tmp_root/bin/apt-get" <<'EOF'
#!/usr/bin/env sh
[ "$1" = "update" ] && exit 0
echo 'E: Could not open lock file /var/lib/dpkg/lock-frontend - open (13: Permission denied)' >&2
exit 100
EOF
  chmod +x "$tmp_root/bin/uname" "$tmp_root/bin/apt-get"

  output="$(
    PATH="$tmp_root/bin:/usr/bin:/bin" \
      HOME="$tmp_home" \
      DOTFILES_DIR_OVERRIDE="$tmp_fixture" \
      "$tmp_fixture/bin/bootstrap" --install 2>&1
  )"

  test -L "$tmp_home/.zshrc"
  test -L "$tmp_home/.gitconfig"
  test -L "$tmp_home/.config/starship.toml"
  assert_contains "$output" "[done] Installed zsh plugin: zsh-autosuggestions"
  assert_contains "$output" "[done] Installed zsh plugin: fast-syntax-highlighting"
  assert_contains "$output" "[warn] Package installation reported actionable issues"
  assert_contains "$output" "sudo ./bin/install-packages"
  assert_occurrences "$output" "Before you finish setup, review these follow-up steps:" 1
  assert_occurrences "$output" 'chsh -s "$(command -v zsh)"' 1

  cleanup_dir "$tmp_root"
  cleanup_dir "$tmp_home"
  cleanup_dir "$tmp_fixture"
}

run_root_plugin_skip_self_test() {
  tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-root.XXXXXX")"
  tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-home.XXXXXX")"
  tmp_fixture="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-fixture.XXXXXX")"
  create_self_test_fixture "$tmp_fixture"

  mkdir -p "$tmp_root/bin"
  cat > "$tmp_root/bin/id" <<'EOF'
#!/usr/bin/env sh
printf '%s\n' "0"
EOF
  chmod +x "$tmp_root/bin/id"

  output="$(
    PATH="$tmp_root/bin:/usr/bin:/bin" \
      HOME="$tmp_home" \
      DOTFILES_DIR_OVERRIDE="$tmp_fixture" \
      "$tmp_fixture/bin/bootstrap" 2>&1
  )"

  assert_contains "$output" "[warn] Skipping zsh plugin installation because bootstrap is running as root"
  assert_contains "$output" "Run ./bin/install-zsh-plugins as your normal user after bootstrap completes"

  cleanup_dir "$tmp_root"
  cleanup_dir "$tmp_home"
  cleanup_dir "$tmp_fixture"
}

run_fzf_legacy_fallback_self_test() {
  tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-fzf.XXXXXX")"
  tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-home.XXXXXX")"
  tmp_fixture="$(mktemp -d "${TMPDIR:-/tmp}/bootstrap-fixture.XXXXXX")"
  create_self_test_fixture "$tmp_fixture"

  mkdir -p "$tmp_root/bin" "$tmp_root/share/fzf"
  cat > "$tmp_root/bin/fzf" <<'EOF'
#!/usr/bin/env sh
printf '%s\n' "unknown option: $1" >&2
exit 1
EOF
  cat > "$tmp_root/share/fzf/key-bindings.zsh" <<'EOF'
legacy-fzf-binding() { :; }
EOF
  chmod +x "$tmp_root/bin/fzf"

  output="$(
    PATH="$tmp_root/bin:/usr/bin:/bin" \
      HOME="$tmp_home" \
      FZF_BASE="$tmp_root/share/fzf" \
      DOTFILES_DIR_OVERRIDE="$tmp_fixture" \
      zsh -c '. "$DOTFILES_DIR_OVERRIDE/zsh/.zshrc"; whence -w legacy-fzf-binding' 2>&1
  )"

  assert_contains "$output" "legacy-fzf-binding: function"
  if printf '%s' "$output" | grep -F -- "unknown option: --zsh" >/dev/null 2>&1; then
    printf '%s\n' "legacy fzf fallback still emitted --zsh error" >&2
    return 1
  fi

  cleanup_dir "$tmp_root"
  cleanup_dir "$tmp_home"
  cleanup_dir "$tmp_fixture"
}

run_self_test() {
  case "${2:-}" in
    progress-output)
      run_progress_output_self_test
      ;;
    install-delegation)
      run_install_delegation_self_test
      ;;
    root-plugin-skip)
      run_root_plugin_skip_self_test
      ;;
    fzf-legacy-fallback)
      run_fzf_legacy_fallback_self_test
      ;;
    *)
      printf '%s\n' "unknown self-test: ${2:-}" >&2
      return 1
      ;;
  esac
}

main() {
  log_info "Starting bootstrap"

  seed_local_file "$DOTFILES_DIR/local/zsh.local.example" "$DOTFILES_DIR/local/zsh.local"
  seed_local_file "$DOTFILES_DIR/local/gitconfig.local.example" "$DOTFILES_DIR/local/gitconfig.local"

  link_file "$DOTFILES_DIR/zsh/.zshrc" "$HOME/.zshrc"
  link_file "$DOTFILES_DIR/git/.gitconfig" "$HOME/.gitconfig"
  link_file "$DOTFILES_DIR/starship/starship.toml" "$HOME/.config/starship.toml"
  if is_root; then
    log_warn "Skipping zsh plugin installation because bootstrap is running as root"
    log_info "Run ./bin/install-zsh-plugins as your normal user after bootstrap completes"
  else
    "$DOTFILES_DIR/bin/install-zsh-plugins"
  fi

  if [ "${1:-}" = "--install" ]; then
    if ! "$DOTFILES_DIR/bin/install-packages"; then
      log_warn "Package installation reported actionable issues"
    fi
  else
    print_shell_follow_up
  fi

  log_done "Bootstrap complete"
}

if [ "${1:-}" = "--self-test" ]; then
  run_self_test "$@"
  exit $?
fi

main "$@"
